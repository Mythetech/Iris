@using Iris.Components.History
@using Iris.Components.NativeMenu.Commands
@using Iris.Components.Shared.Dialogs
@using Iris.Desktop.History
@inherits Mythetech.Framework.Infrastructure.MessageBus.ComponentConsumer<ClearHistory>

@code {
    [Inject] IDialogService DialogService { get; set; } = default!;
    [Inject] HistoryRepository Repository { get; set; } = default!;
    [Inject] HistoryState State { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;

    protected override async Task Consume(ClearHistory message, CancellationToken cancellationToken)
    {
        var parameters = new DialogParameters<BasicDialog>
        {
            { x => x.ContentText, "Do you really want to delete all local history?" },
            { x => x.ButtonText, "Delete" },
            { x => x.Color, Color.Error }
        };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small };

        var dialogRef = await DialogService.ShowAsync<BasicDialog>("Delete History", parameters, options);
        var result = await dialogRef.Result;

        if (result is { Canceled: false, Data: not null } && (bool)result.Data)
        {
            Repository.DeleteHistory();
            State.Refresh();
            Snackbar.Add("Successfully cleared local history", Severity.Success);
        }
    }
}
