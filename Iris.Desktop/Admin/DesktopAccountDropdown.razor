@using Iris.Components.Theme    
@using MudBlazor.Extensions
<div>
    <MudTooltip Text="Account">
        <MudIconButton Size="MudBlazor.Size.Small" class="toggle-btn" Icon="@($"{IrisIcons.Account} fs-6")" OnClick="ToggleMenu" />
    </MudTooltip>
    <MudPopover Open="@_open" Class="iris-rainbow-shadow glassmorphic-bg" Style="backdrop-filter: blur(8px) brightness(0.2);" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
        <MudStack Row="true">
            <span class="text-muted" style="font-size:0.75em;">@($"Version {AppVersion.ToString()}")</span>
            <FlexSpacer/>
            <MudLink Target="_blank" Href="https://discord.gg/gQcBw2eHkM">
                <IconButton Name="@IrisIcons.Support" Title="Support"/>
            </MudLink>
            <IconButton Color="Color.Error" Class="icon-btn-danger" Name="@IrisIcons.Bug" Title="Report Bug" ButtonClicked="OpenBugReportModal"/>
        </MudStack>
    </MudPopover>
</div>
@code {
    [Inject] protected ISnackbar Snackbar { get; set; } = default!;
    [Inject] protected IDialogService DialogService { get; set; } = default!;
        
    private bool _open = false;
    
    protected static Version AppVersion => System.Reflection.Assembly.GetExecutingAssembly().GetName().Version ?? throw new NullReferenceException();
    
    private void ToggleMenu()
    {
        _open = !_open;
        StateHasChanged();
    }
        
    protected async Task OpenBugReportModal()
    {
        var options = new DialogOptions() { CloseButton = true, CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
            
        var dialogRef = await DialogService.ShowAsync<BugReportDialog>(title: "🐛 Bug Report", options);

        ToggleMenu();
            
        var result = (await dialogRef.Result)?.Data?.As<Result<bool>>();
            
        if(result != null)
            HandleResult(result);
            
        dialogRef.Close();
    }
        

    protected void HandleResult(Result<bool> result)
    {
        if (result.Error || !result.Value)
        {
            Snackbar.Add("Error submitting bug report 🐛", Severity.Error);
        }
        else
        {
            Snackbar.Add("Submitted bug report successfully!", Severity.Success);

        }

        StateHasChanged();
    }
}