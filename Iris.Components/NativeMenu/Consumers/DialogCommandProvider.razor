@using Iris.Components.NativeMenu.Commands
@inherits Mythetech.Framework.Infrastructure.MessageBus.ComponentConsumer<ShowDialog>

@code {
    [Inject] IDialogService DialogService { get; set; } = default!;

    protected override async Task Consume(ShowDialog message, CancellationToken cancellationToken)
    {
        var options = message.Options ?? new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Medium
        };

        var dialogRef = await DialogService.ShowAsync(
            message.Dialog,
            message.Title,
            message.Parameters ?? new(),
            options);

        await dialogRef.Result;
    }
}
