@using Iris.Contracts.Assemblies.Models
<MudPaper Outlined="true" Elevation="0" class="pa-4 m-2" >
    <MudList T="TypeData" Dense="true">
        @foreach (var prop in Data?.Properties ?? new())
        {
            <MudListItem>
                <MudStack Row AlignItems="AlignItems.Center">
                    <TypeIcon Type="@(prop.Value)"/>
                    <MudText>@prop.Key</MudText>
                    <MudSpacer /> 
                    <MudChip Variant="Variant.Text" Size="Size.Small" Color="Color.Info">@prop.Value</MudChip>
                </MudStack>
            </MudListItem>
        }
    </MudList>
</MudPaper>

@code {
    [Parameter] public TypeData Data { get; set; }
}
