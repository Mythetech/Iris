@using Contracts.Assemblies.Models
@using Iris.Components.Shared.Snackbar
@using Iris.Components.Theme
@using Iris.Components.Shared.Toolbar
@using Mythetech.Framework.Infrastructure.Files
@page "/Packages"
@inherits IrisPageBase

<IrisToolBar Class="mb-4">
    <MudSpacer/>
    <IrisLoadingButton
        Text="Upload Package"
        Loading="@Uploading"
        LoadingText="Uploading"
        Icon="@IrisIcons.UploadPackage"
        OnClick="OpenFileAndUpload"/>
</IrisToolBar>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="overflow-y-auto" Style="max-height:80dvh;">
<PackageTreeView 
    Assemblies="@Assemblies" 
    OnTypeDataRowClicked="ShowTypeDataDetails"/>
</MudContainer>

@if (Assemblies?.Count < 1)
{
    <MudStack Class="w-100" Justify="Justify.Center" AlignItems="AlignItems.Center" Style="@($"height:300px;")">
        <MudIcon Size="MudBlazor.Size.Large" Icon="@IrisIcons.NoPackages"/>
        <MudText>No Packages</MudText>
        <MudText>Iris can use an uploaded assembly to try and automatically match a message broker's endpoint to the expected matching JSON structure.</MudText>
    </MudStack>
}

<MudDrawer @bind-Open="IsOpen" Variant="DrawerVariant.Temporary" Anchor="Anchor.End">
    @if (IsOpen)
    {
        <TypeDataDetails Data="@SelectedType"/>
    }
</MudDrawer>
@code {
    [Inject]
    protected IPackageService PackageService { get; set; } = default!;

    [Inject]
    protected IFileOpenService FileOpenService { get; set; } = default!;

    public override string Identifier { get; set; } = "Packages";

    protected List<TypeData>? Types { get; set; }

    protected List<AssemblyData>? Assemblies { get; set; }

    protected bool Loading { get; set; } = false;

    private bool Uploading { get; set; } = false;

    private bool IsOpen { get; set; } = false;

    private TypeData? SelectedType { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        if (Assemblies == null || Assemblies.Count < 1)
        {
            Loading = true;
            StateHasChanged();

            Assemblies = await PackageService.GetLoadedAssembliesAsync();
            Types = Assemblies.SelectMany(x => x.ExportedTypes).ToList();
            Loading = false;
            StateHasChanged();
        };

        await base.OnInitializedAsync();
    }

    private async Task OpenFileAndUpload()
    {
        var files = await FileOpenService.OpenFileAsync(
            title: "Select Assembly",
            filters: [new FileFilter("Assemblies", ["dll"])]);

        if (files.Length == 0)
            return;

        Uploading = true;
        StateHasChanged();

        var result = await PackageService.UploadAssemblyAsync(files[0]);

        Uploading = false;
        StateHasChanged();

        HandleFileUploadResponse(result);
    }

    private void HandleFileUploadResponse(Result<AssemblyData?> result)
    {
        if (result.Value != null)
        {
            Snackbar.AddIrisNotification("Uploaded package successfully", Severity.Success);
            Assemblies.Add(result.Value);
            StateHasChanged();
        }
        else
        {
            string error = string.IsNullOrWhiteSpace(result.Message) ? "Error uploading package" : result.Message;
            Snackbar.AddIrisNotification(error, Severity.Error);
        }
    }

    protected void ShowTypeDataDetails(TypeData data)
    {
        SelectedType = data;
        IsOpen = true;
        StateHasChanged();
    }
}

