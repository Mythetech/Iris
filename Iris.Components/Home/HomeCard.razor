@inherits IrisBaseComponent

<MudPaper Class="@($"rounded box-shadow-primary pa-4 {Class}")" Style="@($"height:{Height};{Style}")" Elevation="0">
    @ChildContent
</MudPaper>

@code {
    [Parameter]
    public RenderFragment ChildContent { get; set; } = default!;

    [Parameter]
    public string Height { get; set; } = "300px";
}
