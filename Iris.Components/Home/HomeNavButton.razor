@using Iris.Components.Theme
@using Microsoft.AspNetCore.Components.Routing
@implements IDisposable
@inject NavigationManager Nav

<MudTooltip Text="Home" Color="Color.Primary" Disabled="@IsActive">
    <MudIconButton Color="@(IsActive ? Color.Primary : Color.Default)"
                   Icon="@IrisIcons.Home"
                   OnClick="HandleClick" />
</MudTooltip>

@code {
    private bool IsActive => Nav.ToBaseRelativePath(Nav.Uri).TrimStart('/').Length == 0;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void HandleClick()
    {
        if (IsActive)
            return;

        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
