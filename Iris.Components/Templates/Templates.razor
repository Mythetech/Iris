@page "/Templates"
@using Iris.Components.Theme
@using Iris.Contracts.Templates.Models
@inherits IrisPageBase
@implements IDisposable

<IrisCard HeaderIcon="@IrisIcons.Templates" Title="Templates" Height="90vh">
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="d-flex gap-4 mt-2 overflow-auto" Style="flex-direction:column;">
        <MudToolBar>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@IrisIcons.Add"
                       OnClick="@(() => NavigationManager.NavigateTo("/Templates/new"))">
                New Template
            </MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString"
                          Placeholder="Search"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@IrisIcons.Search"
                          Immediate="true"
                          Style="max-width:300px;" />
        </MudToolBar>

        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="w-100" Style="height:300px;">
                <MudProgressCircular Indeterminate="true" />
            </MudStack>
        }
        else if (FilteredTemplates.Count == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="w-100" Style="height:300px;">
                <MudIcon Icon="@IrisIcons.Templates" Size="Size.Large" Class="mud-text-secondary mb-2" />
                <MudText Typo="Typo.h6">No Templates</MudText>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">Create a template to get started</MudText>
            </MudStack>
        }
        else
        {
            <MudGrid>
                @foreach (var template in FilteredTemplates)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <TemplateCard Template="template"
                                      FullMode="true"
                                      OnPreview="ShowPreview"
                                      OnCopy="CopyTemplate"
                                      OnExport="ExportTemplate"
                                      OnDuplicate="DuplicateTemplate"
                                      OnDelete="DeleteTemplate"
                                      OnRenamed="RenameTemplate" />
                    </MudItem>
                }
            </MudGrid>
        }
    </MudContainer>
</IrisCard>

@code {
    [Inject] TemplatesState TemplatesState { get; set; } = default!;
    [Inject] IDialogService DialogService { get; set; } = default!;
    [Inject] IJsApiService JsApi { get; set; } = default!;

    public override string Identifier => "Templates";

    private List<Template> _templates = [];
    private bool _loading = true;
    private string _searchString = "";

    private List<Template> FilteredTemplates =>
        string.IsNullOrWhiteSpace(_searchString)
            ? _templates
            : _templates
                .Where(t =>
                    t.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ||
                    t.Json.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
                .ToList();

    protected override void OnInitialized()
    {
        base.OnInitialized();
        TemplatesState.TemplateStateChanged += RefreshTemplates;
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _templates = await TemplatesState.GetTemplatesAsync() ?? [];
        _loading = false;
    }

    private async void RefreshTemplates()
    {
        _templates = await TemplatesState.GetTemplatesAsync() ?? [];
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowPreview(Template template)
    {
        await DialogService.ShowAsync<TemplatePreviewDialog>(
            string.Empty,
            new DialogParameters { { nameof(TemplatePreviewDialog.Template), template } },
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseOnEscapeKey = true, BackgroundClass = "iris-dialog" });
    }

    private async Task CopyTemplate(Template template)
    {
        await JsApi.CopyToClipboardAsync(template.FormattedJson);
    }

    private async Task ExportTemplate(Template template)
    {
        // TODO: file download
        await JsApi.CopyToClipboardAsync(template.FormattedJson);
    }

    private async Task DuplicateTemplate(Template template)
    {
        await TemplatesState.DuplicateTemplateAsync(template);
    }

    private async Task DeleteTemplate(Template template)
    {
        await TemplatesState.DeleteTemplateAsync(template);
    }

    private async Task RenameTemplate(Template template)
    {
        await TemplatesState.UpdateTemplateAsync(template);
    }

    public void Dispose()
    {
        TemplatesState.TemplateStateChanged -= RefreshTemplates;
    }
}
