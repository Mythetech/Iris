@namespace Iris.Components.CommandPalette
@using MudBlazor.Utilities
@using Iris.Components.Help
@inject CommandPaletteService Palette
@inject IDialogService DialogService

@*
    Headless mount point for the command palette and global hotkeys.
    Drop a single <CommandPaletteHost /> into MainLayout (or any host's
    main layout) and global shortcuts become available app-wide.

    Two MudHotkey instances per shortcut are required because MudHotkey
    treats KeyModifiers as logical AND, not OR — there's no single binding
    that means "Ctrl OR Meta".
*@

@* Command Palette: Cmd/Ctrl + K *@
<MudHotkey Key="JsKey.KeyK"
           KeyModifiers="@_ctrlOnly"
           OnHotkeyPressed="OpenPaletteAsync" />
<MudHotkey Key="JsKey.KeyK"
           KeyModifiers="@_metaOnly"
           OnHotkeyPressed="OpenPaletteAsync" />

@* Keyboard Shortcuts: Cmd/Ctrl + ? (Shift + /) *@
<MudHotkey Key="JsKey.Slash"
           KeyModifiers="@_ctrlShift"
           OnHotkeyPressed="OpenKeyboardShortcutsAsync" />
<MudHotkey Key="JsKey.Slash"
           KeyModifiers="@_metaShift"
           OnHotkeyPressed="OpenKeyboardShortcutsAsync" />

@code {
    private static readonly IEnumerable<JsKeyModifier> _ctrlOnly = new[] { JsKeyModifier.ControlLeft };
    private static readonly IEnumerable<JsKeyModifier> _metaOnly = new[] { JsKeyModifier.MetaLeft };
    private static readonly IEnumerable<JsKeyModifier> _ctrlShift = new[] { JsKeyModifier.ControlLeft, JsKeyModifier.ShiftLeft };
    private static readonly IEnumerable<JsKeyModifier> _metaShift = new[] { JsKeyModifier.MetaLeft, JsKeyModifier.ShiftLeft };

    private static readonly DialogOptions _paletteOptions = new()
    {
        NoHeader = true,
        CloseOnEscapeKey = true,
        BackdropClick = true,
        Position = DialogPosition.TopCenter,
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
    };

    private static readonly DialogOptions _shortcutsOptions = new()
    {
        CloseOnEscapeKey = true,
        BackgroundClass = "iris-dialog",
        MaxWidth = MaxWidth.Small,
    };

    private async Task OpenPaletteAsync()
    {
        if (Palette.IsOpen)
        {
            return;
        }

        await DialogService.ShowAsync(typeof(CommandPaletteDialog), string.Empty, _paletteOptions);
    }

    private async Task OpenKeyboardShortcutsAsync()
    {
        await DialogService.ShowAsync(typeof(KeyboardShortcutsDialog), "Keyboard Shortcuts", _shortcutsOptions);
    }
}
