<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="@($"key-value-row w-100 {Class}")">
    <MudText Typo="Typo.body2" Class="text-muted">@Key</MudText>
    <FlexSpacer/>
    <MudText Typo="Typo.body2" Class="key-value-row-value">@(Value ?? "—")</MudText>
</MudStack>

@code {
    [Parameter, EditorRequired]
    public string Key { get; set; } = default!;

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string Class { get; set; } = "";
}
