@using Iris.Components.Theme

<div @onclick:stopPropagation="true">
    <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight">
        <ActivatorContent>
            <MudIconButton Size="Size.Small" Icon="@IrisIcons.MoreOptions" OnClick="@context.ToggleAsync" Title="Actions" />
        </ActivatorContent>
        <ChildContent>
            @foreach (var item in Actions)
            {
                <MudMenuItem Class="d-flex" OnClick="@(async () => await ActionSelected.InvokeAsync(item))">
                    @item.Text
                    <FlexSpacer/>
                    <MudIcon Icon="@item.Icon"></MudIcon>
                </MudMenuItem>
            }
        </ChildContent>
    </MudMenu>
</div>

@code {
    public class ActionMenuModel
    {
        public string Icon { get; set; } = "";
        public string Text { get; set; } = "";
    }

    [Parameter]
    public List<ActionMenuModel> Actions { get; set; } = default!;

    [Parameter]
    public EventCallback<ActionMenuModel> ActionSelected { get; set; } = default!;
}
