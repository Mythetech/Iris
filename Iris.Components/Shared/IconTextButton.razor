@inherits IrisBaseComponent

<MudButton Variant="Variant.Text" Color="@Color" OnClick="@OnClick" Class="@Class" Style="@Style">
    <MudIcon Size="Size.Small" Icon="@Icon" Class="mr-2" />
    @Text
</MudButton>

@code {
    [Parameter] public EventCallback OnClick { get; set; } = default!;

    [Parameter] public string Icon { get; set; } = @IrisIcons.Add;

    [Parameter] public string Text { get; set; } = "Add Property";

    [Parameter] public Color Color { get; set; } = Color.Primary;
}