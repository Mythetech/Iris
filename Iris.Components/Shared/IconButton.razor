@inherits Iris.Components.IrisBaseComponent

<MudTooltip Text="@Title">
    <MudIconButton Color="@Color" Class="@($"icon-btn {Class}")" OnClick="@ButtonClicked" Style="@($"{Style} width:1.875rem;height:1.875rem;")" Disabled="@Disabled">
        <MudIcon Size="Size.Small" Icon="@Name" Style="font-size:1rem;" />
        @ChildContent
    </MudIconButton>
</MudTooltip>

@code {
    [Parameter]
    public string Title { get; set; } = "";

    [Parameter] public string Name { get; set; } = default!;

    [Parameter]
    public EventCallback ButtonClicked { get; set; } = default!;

    [Parameter]
    public RenderFragment ChildContent { get; set; } = default!;

    [Parameter] public Color Color { get; set; } = Color.Primary;

    [Parameter] public bool Disabled { get; set; } = false;

}