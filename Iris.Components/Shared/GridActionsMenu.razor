@using Iris.Components.Theme

<div @onclick:stopPropagation="true">
    <MudMenu Dense="true" AnchorOrigin="Origin.BottomRight">
        <ActivatorContent>
            <MudIconButton Size="Size.Small" Icon="@IrisIcons.MoreOptions" OnClick="@context.ToggleAsync" Title="Actions" />
        </ActivatorContent>
        <ChildContent>
        <MudMenuItem Class="d-flex w-100" OnClick="HandleSendClicked">
            <MudStack Row="true">
                <MudText Class="mr-4">Send</MudText> <MudIcon Icon="@IrisIcons.Send"></MudIcon>
            </MudStack>
        </MudMenuItem>
        <MudTooltip Text="@(CanRead ? "Peek or receive messages" : ReadDisabledReason)">
            <MudMenuItem Class="d-flex w-100" OnClick="HandleReadClicked" Disabled="@(!CanRead)">
                <MudStack Row="true">
                    <MudText Class="mr-4">Read</MudText> <MudIcon Icon="@Icons.Material.Filled.Inbox"></MudIcon>
                </MudStack>
            </MudMenuItem>
        </MudTooltip>
        </ChildContent>
    </MudMenu>
</div>

@code {

    [Parameter] public EventCallback OnViewClicked { get; set; }
    [Parameter] public EventCallback OnSendClicked { get; set; }
    [Parameter] public EventCallback OnReadClicked { get; set; }
    [Parameter] public bool CanRead { get; set; }
    [Parameter] public string ReadDisabledReason { get; set; } = "Broker does not support reading messages";

    private async Task HandleViewClicked()
    {
        await OnViewClicked.InvokeAsync(null);
    }

    private async Task HandleSendClicked()
    {
        await OnSendClicked.InvokeAsync(null);
    }

    private async Task HandleReadClicked()
    {
        await OnReadClicked.InvokeAsync(null);
    }
}