@implements IDisposable

<MudContainer Class="d-flex" Style="justify-content:center;align-items:center;flex-direction:column;text-align:center;min-height:75vh;" MaxWidth="MaxWidth.Small">
    <MudStack Class="mud-width-full" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="1" Row="true">
        <MudStack Spacing="0">
            <IrisWing Class="@(Animations[2] == MudBlazor.Animation.False ? "opacity-25" : "")" Animation="@Animations[2]" Style="margin-top:-4em;z-index:30;transform:rotate(-10deg);margin-left:2em;" Height="110px" Width="65px" Reverse="true" ShadowColor="#3498db" />
            <IrisWing Class="@(Animations[1] == MudBlazor.Animation.False ? "opacity-25" : "")" Animation="@Animations[1]" Style="margin-top:-4em;margin-left:1.5em;z-index:20;" Reverse="true" Width="65px" ShadowColor="#00bc8c" />
            <IrisWing Class="@(Animations[0] == MudBlazor.Animation.False ? "opacity-25" : "")" Animation="@Animations[0]" Style="margin-top: -2em;margin-left:2em;z-index:10; transform: rotate(-40deg);" Height="50px" Width="65px" Reverse="true" ShadowColor="#fd7e14" />
        </MudStack>
        <MudStack>
            <MudSkeleton Animation="MudBlazor.Animation.False" Class="bg-black" Style="z-index:50;box-shadow: 0 0 0.7em 0.7em var(--iris-accent);margin-left:0.35em;" SkeletonType="SkeletonType.Circle" Height="30px" Width="30px" />
            <MudSkeleton Animation="MudBlazor.Animation.False" Class="bg-black" Style="z-index:50;box-shadow: 0 0 0.5em 0.5em var(--bs-primary);margin-bottom:0.5em;" SkeletonType="SkeletonType.Circle" Height="40px" Width="40px" />
        </MudStack>
        <MudStack Spacing="0">
            <IrisWing Class="@(Animations[3] == MudBlazor.Animation.False ? "opacity-25" : "")" Animation="@Animations[3]" Style="margin-top: -4em; z-index: 30; transform: rotate(10deg); " Height="110px" Width="65px" ShadowColor="#0d6efd" />
            <IrisWing Class="@(Animations[4] == MudBlazor.Animation.False ? "opacity-25" : "")" Animation="@Animations[4]" Style="margin-top:-4em;margin-left:0.5em;z-index:20;" Width="65px" ShadowColor="#6610f2" />
            <IrisWing Class="@(Animations[5] == MudBlazor.Animation.False ? "opacity-25" : "")" Animation="@Animations[5]" Style="margin-top: -2em;margin-left:0em; z-index: 10; transform: rotate(40deg);" Height="50px" Width="65px" ShadowColor="#e83e8c" />
        </MudStack>
    </MudStack>
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="w-100 my-4" />
    <MudText Class="text-muted">Loading Iris...</MudText>
</MudContainer>

@code {
    private int counter = 0;
    private CancellationTokenSource cts = default!;

    private List<MudBlazor.Animation> Animations = [
    MudBlazor.Animation.False,
    MudBlazor.Animation.False,
    MudBlazor.Animation.False,
    MudBlazor.Animation.False,
    MudBlazor.Animation.False,
    MudBlazor.Animation.False
    ];

    protected override async Task OnInitializedAsync()
    {
        cts = new CancellationTokenSource();
        LoopAnimations(cts.Token);
        await Task.CompletedTask;
    }

    public void Dispose()
    {
        Dispose(true);
        GC.SuppressFinalize(this);
    }

    protected virtual void Dispose(bool disposing)
    {
        if (disposing)
        {
            cts.Cancel();
        }
    }

    private async void LoopAnimations(CancellationToken token)
    {
        while (true)
        {
            if (token.IsCancellationRequested)
            {
                break;
            }
            if (counter >= 6)
            {
                counter = 0;
                StateHasChanged();
            }
            StateHasChanged();
            Animations[counter] = MudBlazor.Animation.Pulse;
            StateHasChanged();
            await Task.Delay(2850);
            Animations[counter >= 5 ? 0 : counter + 1] = MudBlazor.Animation.Pulse;
            StateHasChanged();
            await Task.Delay(75);
            Animations[counter] = MudBlazor.Animation.False;
            StateHasChanged();
            counter += 1;
        }
    }
}