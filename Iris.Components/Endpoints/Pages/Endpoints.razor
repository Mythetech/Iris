@inherits IrisPageBase
@using Iris.Components.Brokers
@using Iris.Components.Messaging
@using Iris.Components.Theme
@using Iris.Contracts.Brokers.Models
@page "/Endpoints"

<IrisCard>
    <MudDataGrid Loading="@Loading"
                 RowsPerPage="10"
                 Items="@_endpoints"
                 T="Contracts.Brokers.Models.EndpointDetails"
                 Hover="true"
                 RowClick="EndpointRowClicked"
                 Class="iris-table"
                 Filterable="false"
                 Dense="true"
                 QuickFilter="@_quickFilter">
        <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                          AdornmentIcon="@Icons.Material.Filled.Search" IconSize="MudBlazor.Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <Columns>
            <TemplateColumn CellClass="grid-icon-col" Filterable="false">
                <CellTemplate>
                    <MudTooltip Text="@(context?.Item?.Provider ?? " Provider")">
                        <MudIcon Size="Size.Small" Class="@($"icon-{context?.Item?.Provider}")" />
                    </MudTooltip>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x!.Provider" Title="Provider" />
            <PropertyColumn Property="x => x!.Address" Title="Address" />
            <PropertyColumn Property="x => x!.Name" Title="Name" />
            <PropertyColumn Property="x => x!.Type" Title="Type" />
            <TemplateColumn CellClass="grid-icon-col" Filterable="false">
                <CellTemplate>
                    <GridActionsMenu
                        OnSendClicked="@(() => HandleSendClicked(context?.Item!))"
                        OnReadClicked="@(() => HandleReadClicked(context?.Item!))"
                        CanRead="@CanRead(context?.Item)"
                        ReadDisabledReason="@GetReadDisabledReason(context?.Item)" />
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="Contracts.Brokers.Models.EndpointDetails" />
        </PagerContent>
        <LoadingContent>
            <MudPaper Class="mud-width-full bg-black" Square="true" Style="margin-top:-1em;margin-bottom:-1em;overflow:hidden;">
                <MudGrid Class="pa-4">
                    @for (int i = 0; i < 11; i++)
                    {
                        <MudItem xs="1">
                            <MudSkeleton Class="loading-box-shadow" SkeletonType="SkeletonType.Rectangle" Height="32px" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudSkeleton Class="loading-box-shadow" SkeletonType="SkeletonType.Rectangle" Height="32px" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudSkeleton Class="loading-box-shadow" SkeletonType="SkeletonType.Rectangle" Height="32px" />
                        </MudItem>
                        <MudItem xs="2">
                            <MudSkeleton Class="loading-box-shadow" SkeletonType="SkeletonType.Rectangle" Height="32px" />
                        </MudItem>
                        <MudItem xs="1">
                            <MudSkeleton Class="loading-box-shadow" SkeletonType="SkeletonType.Rectangle" Height="32px" />
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>
        </LoadingContent>
        <NoRecordsContent>
            <MudStack Class="w-100" Justify="Justify.Center" AlignItems="AlignItems.Center" Style="@($"height:245px;")">
                <MudIcon Size="MudBlazor.Size.Large" Icon="@IrisIcons.NoEndpoints" />
                <MudText>No Endpoints</MudText>
            </MudStack>
        </NoRecordsContent>
    </MudDataGrid>
</IrisCard>
<MudDrawer @bind-Open="_isOpen" Variant="DrawerVariant.Temporary" Anchor="Anchor.End">
    <EndpointOffcanvas Endpoint="@_selectedEndpoint"/>
</MudDrawer>
@code {
    [Inject]
    public IBrokerService Client { get; set; } = default!;

    [Inject]
    public IDialogService DialogService { get; set; } = default!;

    private List<Contracts.Brokers.Models.EndpointDetails> _endpoints = new();

    private readonly Dictionary<string, ReaderCapabilitiesDto?> _caps = new();

    private MudDataGrid<Contracts.Brokers.Models.EndpointDetails> _grid { get; set; } = default!;

    private bool Loading = true;

    private string? _searchString;

    protected override async Task OnInitializedAsync()
    {
        if (_endpoints is null || _endpoints.Count == 0)
        {
            Loading = true;

            StateHasChanged();

            _endpoints = await Client.GetEndpointsAsync();

            // Probe reader capabilities once per distinct connection address.
            // The dialog uses these to decide which Peek/Receive/DLQ buttons
            // to show; the actions menu uses CanReceive as the floor for
            // enabling the Read item.
            foreach (var addr in _endpoints.Select(e => e.Address).Distinct())
                _caps[addr] = await Client.GetReaderCapabilitiesAsync(addr);

            Loading = false;
        }

        StateHasChanged();

        await base.OnInitializedAsync();
    }

    private bool CanRead(Contracts.Brokers.Models.EndpointDetails? e) =>
        e is not null
        && string.Equals(e.Type, "Queue", StringComparison.OrdinalIgnoreCase)
        && _caps.TryGetValue(e.Address, out var c)
        && c?.CanReceive == true;

    private string GetReadDisabledReason(Contracts.Brokers.Models.EndpointDetails? e)
    {
        if (e is null)
            return "Unknown endpoint";
        if (!string.Equals(e.Type, "Queue", StringComparison.OrdinalIgnoreCase))
            return "Reading is only supported for queue endpoints";
        return "Broker does not support reading messages";
    }

    private async Task HandleReadClicked(Contracts.Brokers.Models.EndpointDetails endpoint)
    {
        if (!_caps.TryGetValue(endpoint.Address, out var caps) || caps is null)
            return;

        var parameters = new DialogParameters
        {
            ["Endpoint"] = endpoint,
            ["Capabilities"] = caps,
        };
        await DialogService.ShowAsync<MessageReaderDialog>(
            $"Read {endpoint.Name}", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    protected void EndpointRowClicked(DataGridRowClickEventArgs<Contracts.Brokers.Models.EndpointDetails> args)
    {
        ShowEndpointOffcanvas(args.Item);
    }

    private EndpointDetails? _selectedEndpoint;
    private bool _isOpen = false;
    
    private void ShowEndpointOffcanvas(Contracts.Brokers.Models.EndpointDetails endpoint)
    {
        _selectedEndpoint = endpoint;
        _isOpen = true;
        StateHasChanged();
    }

    private void HandleSendClicked(Contracts.Brokers.Models.EndpointDetails endpoint)
    {
        NavigationManager.NavigateTo($"/Messaging?Provider={endpoint.Address}&Endpoint={endpoint.Name}");
    }

    private Func<Contracts.Brokers.Models.EndpointDetails, bool> _quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;

        if (x.Name.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Address.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x.Provider.Contains(_searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        if (x?.Type?.Contains(_searchString, StringComparison.OrdinalIgnoreCase) ?? false)
            return true;

        return false;
    };

}

