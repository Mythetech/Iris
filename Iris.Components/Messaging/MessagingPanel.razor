@using Iris.Components.Theme

<MudStack Class="pa-2 w-100" Spacing="0">
    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true"
               EndIcon="@Icons.Material.Filled.OpenInNew" OnClick="OpenMessagingPage">
        Open Messaging Page
    </MudButton>

    <MudDivider Class="my-2" />

    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="w-100 flex-grow-1">
        <MudIcon Icon="@IrisIcons.Send" Size="Size.Large" Class="mud-text-secondary mb-2" />
        <MudText Typo="Typo.body2" Align="MudBlazor.Align.Center" Class="mud-text-secondary mb-3">
            Compose and send messages to your connected broker endpoints.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@IrisIcons.Send" OnClick="OpenMessagingPage">
            New Message
        </MudButton>
    </MudStack>
</MudStack>

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;

    private void OpenMessagingPage() => NavigationManager.NavigateTo("/Messaging");
}
