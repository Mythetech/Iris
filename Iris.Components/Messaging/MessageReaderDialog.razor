@using System.Text.Json
@using Iris.Components.Shared.JsonTreeView
@using Iris.Contracts.Brokers.Models
@using Iris.Contracts.Messaging.Models
@using Iris.Contracts.Results

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Inbox" />
            <MudText Typo="Typo.h6">Read @Endpoint.Name</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudAlert Severity="Severity.Warning" Dense="true">
                Receive is destructive — messages are removed from the queue and cannot be put back.
                Use Peek for a non-destructive preview when available.
            </MudAlert>

            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudNumericField T="int" @bind-Value="_count" Label="Count" Min="1" Max="@MaxBatch" Style="width:110px" />
                @if (Capabilities.CanPeekDeadLetter || Capabilities.CanReceiveDeadLetter)
                {
                    <MudSwitch T="bool" @bind-Value="_dlq" Label="Dead-letter queue" Color="Color.Warning" />
                }
                <MudSpacer />
                @if (EffectiveCanPeek)
                {
                    <MudButton Variant="Variant.Outlined" OnClick="DoPeek" Disabled="@_loading">Peek</MudButton>
                }
                @if (EffectiveCanReceive)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ConfirmReceive" Disabled="@_loading">Receive</MudButton>
                }
            </MudStack>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
            }

            @if (_messages.Count == 0 && !_loading)
            {
                <MudText Typo="Typo.body2" Class="mud-text-secondary">No messages read yet.</MudText>
            }
            else
            {
                <MudExpansionPanels MultiExpansion="true">
                    @foreach (var msg in _messages)
                    {
                        <MudExpansionPanel Text="@($"{msg.MessageId ?? "(no id)"} — {msg.SizeInBytes?.ToString() ?? "?"} bytes")">
                            <SimpleTabs>
                                <Tab Name="Body">
                                    @if (IsJson(msg.Body))
                                    {
                                        <JsonTreeView Json="@msg.Body" Dense="true" Hover="true" />
                                    }
                                    else
                                    {
                                        <MudTextField Value="@msg.Body" ReadOnly="true" Lines="10" Variant="Variant.Outlined" />
                                    }
                                </Tab>
                                <Tab Name="Headers">
                                    @if (msg.Headers.Count == 0)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">No headers.</MudText>
                                    }
                                    else
                                    {
                                        <MudSimpleTable Dense="true">
                                            <thead>
                                                <tr><th>Key</th><th>Value</th></tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var kvp in msg.Headers)
                                                {
                                                    <tr><td>@kvp.Key</td><td>@kvp.Value</td></tr>
                                                }
                                            </tbody>
                                        </MudSimpleTable>
                                    }
                                </Tab>
                            </SimpleTabs>
                        </MudExpansionPanel>
                    }
                </MudExpansionPanels>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter, EditorRequired] public Iris.Contracts.Brokers.Models.EndpointDetails Endpoint { get; set; } = default!;
    [Parameter, EditorRequired] public ReaderCapabilitiesDto Capabilities { get; set; } = default!;

    [Inject] public IMessageService MessageService { get; set; } = default!;
    [Inject] public ISnackbar Snackbar { get; set; } = default!;
    [Inject] public IDialogService DialogService { get; set; } = default!;

    private int _count = 10;
    private bool _dlq;
    private bool _loading;
    private List<ReceivedMessageDto> _messages = new();

    private bool EffectiveCanPeek => _dlq ? Capabilities.CanPeekDeadLetter : Capabilities.CanPeek;
    private bool EffectiveCanReceive => _dlq ? Capabilities.CanReceiveDeadLetter : Capabilities.CanReceive;

    private int MaxBatch
    {
        get
        {
            // Use the larger of peek/receive caps so the numeric input
            // accepts whatever the active mode could request.
            var peek = Capabilities.MaxPeekBatchSize;
            var receive = Capabilities.MaxReceiveBatchSize;
            var max = Math.Max(peek, receive);
            return max > 0 ? max : 100;
        }
    }

    private async Task DoPeek()
    {
        _loading = true;
        try
        {
            var result = _dlq
                ? await MessageService.PeekDeadLetterMessagesAsync(Endpoint.Address, Endpoint.Name, _count)
                : await MessageService.PeekMessagesAsync(Endpoint.Address, Endpoint.Name, _count);
            HandleResult(result);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ConfirmReceive()
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            new MessageBoxOptions
            {
                Title = "Confirm receive",
                Message = $"This will remove up to {_count} messages from {Endpoint.Name}. Continue?",
                YesText = "Receive",
                CancelText = "Cancel",
            });
        if (confirm != true) return;

        _loading = true;
        try
        {
            var result = _dlq
                ? await MessageService.ReceiveDeadLetterMessagesAsync(Endpoint.Address, Endpoint.Name, _count)
                : await MessageService.ReceiveMessagesAsync(Endpoint.Address, Endpoint.Name, _count);
            HandleResult(result);
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleResult(Result<IReadOnlyList<ReceivedMessageDto>> result)
    {
        if (result is Success<IReadOnlyList<ReceivedMessageDto>> success)
        {
            _messages = success.Value.ToList();
        }
        else if (result is Failure<IReadOnlyList<ReceivedMessageDto>> failure)
        {
            Snackbar.Add(failure.Message, Severity.Error);
        }
    }

    private static bool IsJson(string body)
    {
        if (string.IsNullOrWhiteSpace(body)) return false;
        var trimmed = body.TrimStart();
        if (trimmed.Length == 0 || (trimmed[0] != '{' && trimmed[0] != '[')) return false;
        try
        {
            using var _ = JsonDocument.Parse(body);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
