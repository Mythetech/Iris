@page "/Messaging"
@using Iris.Components.Brokers
@using Iris.Components.Templates
@using Iris.Components.Theme
@using Iris.Contracts.Assemblies
@using Iris.Contracts.Assemblies.Models
@using Iris.Components.PackageManagement
@inherits IrisPageBase
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="d-flex gap-4 mud-height-full" Style="flex-direction:column;height: 82dvh;">
    <MudGrid class="mud-height-full">
        <MudItem xs="12">
            <MudToolBar Class="darkmorphic gap-4">
                <ProviderSelector
                    @ref="_providerSelect"
                    Providers="@_providers"
                    @bind-Value="@_selectedProvider"
                />
                
                <EndpointSelector
                    Endpoints="@_endpoints"
                    @bind-Value="@_selectedEndpoint"
                    SelectedProviderAddress="@_selectedProvider?.Address"
                    SelectedEndpointChanged="@TrySetMessageStructure" 
                    />

                <FlexSpacer />
                
                <IrisLoadingButton
                    Loading="@_loading"
                    OnClick="@SendClicked"
                    Icon="@IrisIcons.Send"
                    Text="Send"
                    LoadingText="Sending" />
            </MudToolBar>
        </MudItem>

        <MudItem xs="12" Class="mud-height-full">
            <IrisSplitter SplitterOrientation="Microsoft.Fast.Components.FluentUI.Orientation.Horizontal">
                <Panel1>
                    <MessageEditor
                        @ref="@_editor"
                        OnCreateSampleData="CreateSampleMessageDataAsync"
                        OnImportFromPackage="ImportFromPackageAsync"
                        OnTemplateSaved="SaveTemplateAsync"
                        />
                </Panel1>
                <Panel2>
                    <OptionsPanel />
                </Panel2>
            </IrisSplitter>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Inject]
    public IMessageService MessageService { get; set; } = default!;

    [Inject]
    public IBrokerService BrokerService { get; set; } = default!;

    [Inject]
    public ITemplatesState TemplatesState { get; set; } = default!;
    
    [Inject]
    public MessageState MessageState { get; set; } = default!;

    [Inject]
    public IMessageSendOrchestrator SendOrchestrator { get; set; } = default!;

    [Inject]
    public ISampleJsonGenerator SampleGenerator { get; set; } = default!;

    [Inject]
    public IPackageService PackageService { get; set; } = default!;

    [Inject]
    public IDialogService DialogService { get; set; } = default!;

    [Inject]
    public ITemplateResolver TemplateResolver { get; set; } = default!;

    [SupplyParameterFromQuery]
    public string? Provider { get; set; }

    [SupplyParameterFromQuery]
    public string? Endpoint { get; set; }

    private OptionsPanel OptionPanel { get; set; } = default!;

    private List<EndpointDetails> _endpoints = default!;

    private List<Provider> _providers = default!;

    private ProviderSelector _providerSelect = default!;

    private Provider? _selectedProvider = default!;

    private EndpointDetails? _selectedEndpoint = default!;

    private bool _loading = false;

    private MessageEditor _editor = default!;

    public override string Identifier => "Messaging";

    private List<Iris.Contracts.Templates.Models.Template>? _templates;

    protected override void OnInitialized()
    {
        if (TemplatesState is TemplatesState t)
        {
            t.TemplateLoaded += LoadTemplateToEditor;
        }
        
        base.OnInitialized();
    }

    public void Dispose()
    {
        if (TemplatesState is TemplatesState t)
        {
            t.TemplateLoaded -= LoadTemplateToEditor;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.Yield();

        if ((_endpoints?.Count ?? 0) < 1)
        {
            _endpoints = await BrokerService.GetEndpointsAsync();
        }

        if ((_providers?.Count ?? 0) < 1)
        {
            _providers ??= new();

            var providers = _endpoints?.DistinctBy(x => x.Address).Select(y => y.Address) ?? Enumerable.Empty<string>();

            foreach (var p in providers)
            {
                _providers.Add(new Provider()
                {
                    Address = p,
                    Endpoints = _endpoints?.Count(x => x.Address.Equals(p)) ?? 0,
                    Name = _endpoints?.FirstOrDefault(x => x.Address.Equals(p))?.Provider ?? "",
                });
            }
        }

        if (!string.IsNullOrWhiteSpace(Provider))
        {
            var p = _providers?.FirstOrDefault(x => x.Address == Provider);
            if (p != null)
            {
                _selectedProvider = p;

                var index = _providers?.IndexOf(p);

                if (index > -1)
                {
                    await _providerSelect.SelectOption(_providers?[index ?? 0]!);
                }
            }
        }

        if (!string.IsNullOrWhiteSpace(Endpoint))
        {
            var e = _endpoints?.FirstOrDefault(x => x.Name == Endpoint);
            if (e != null)
            {
                _selectedEndpoint = e;
                StateHasChanged();

                var index = _endpoints?.IndexOf(e);
                if (index > 0)
                {
                    await TrySetMessageStructure(e.Name);
                }
            }
        }

        _templates = await TemplatesState.GetTemplatesAsync();
        
        StateHasChanged();
    }

    private async Task TrySetMessageStructure(string name)
    {
        string message = await this.MessageService.GetMessageStructureAsync(name);

        await SetEditorTextAsync(message);
    }

    private async Task SetEditorTextAsync(string? text)
    {
        await _editor.SetTextAsync(text);
    }

    private async Task SaveTemplateAsync(string json)
    {
        var template = new Iris.Contracts.Templates.Models.Template()
        {
            Json = json,
            Name = Endpoint ?? "Untitled"
        };

        await TemplatesState.CreateTemplateAsync(template);
    }

    protected async Task SendClicked()
    {
        if(!(await _providerSelect.Validate()))
            return;

        _loading = true;

        StateHasChanged();

        string json = await _editor.GetTextAsync() ?? "";

        // Per-iteration progress: matches the pre-extraction behaviour where every
        // send in a Repeat run surfaced its own success/failure snackbar.
        var progress = new Progress<Result<bool>>(r => HandleResult(r));

        await SendOrchestrator.SendAsync(
            new SendContext
            {
                Json = json,
                Provider = _selectedProvider,
                Endpoint = _selectedEndpoint,
            },
            progress);

        _loading = false;

        StateHasChanged();
    }

    protected async Task DeleteTemplate(Contracts.Templates.Models.Template template)
    {
        await TemplatesState.DeleteTemplateAsync(template);
    }

    protected async Task UpdateTemplate(Contracts.Templates.Models.Template template)
    {
        await TemplatesState.UpdateTemplateAsync(template);
    }

    private async void LoadTemplateToEditor(Contracts.Templates.Models.Template template)
    {
        var resolvedJson = await TemplateResolver.ResolveAsync(template.Json);
        await _editor.SetTextAsync(resolvedJson);
    }
    
    private async Task CreateSampleMessageDataAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedEndpoint?.Name))
            return;

        try
        {
            var assemblies = await PackageService.GetLoadedAssembliesAsync();
            var endpointName = _selectedEndpoint.Name.Replace(":", ".");
            var typeData = assemblies
                .SelectMany(a => a.ExportedTypes ?? [])
                .FirstOrDefault(t => t.Name == endpointName || t.FullyQualifiedName == endpointName);

            if (typeData?.Properties == null)
                return;

            await GenerateSampleForType(typeData);
        }
        catch
        {
            // Silently fail — matches previous behavior
        }
    }

    private async Task ImportFromPackageAsync()
    {
        var dialogRef = await DialogService.ShowAsync<TypePickerDialog>(
            string.Empty,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialogRef.Result;

        if (result is { Canceled: false, Data: TypeData typeData })
        {
            await GenerateSampleForType(typeData);
        }
    }

    private async Task GenerateSampleForType(TypeData typeData)
    {
        var sample = SampleGenerator.GenerateSample(typeData);
        await SetEditorTextAsync(sample.ToJsonString(new System.Text.Json.JsonSerializerOptions { WriteIndented = true }));
    }
}