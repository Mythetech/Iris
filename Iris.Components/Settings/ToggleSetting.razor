<MudStack Row>
    <MudText>@SettingName</MudText>
    @if (!string.IsNullOrWhiteSpace(Description))
    {
        <MudText Class="mud-text-secondary">@Description</MudText>
    }
    <MudSpacer />
    <SwitchM3 T="bool" Color="Color.Primary" Value="@Value" ValueChanged="@ValueChanged" />
</MudStack>

@code {
    [Parameter]
    public bool Value { get; set; }
    
    [Parameter]
    public EventCallback<bool> ValueChanged { get; set; }
    
    [Parameter]
    public string SettingName { get; set; }
    
    [Parameter]
    public string? Description { get; set; }
}