@using Iris.Components.Shared.Dividers
<MudStack Spacing="0">
    <MudText Typo="Typo.h6" Class="mud-text-secondary">
        @Section.Name
    </MudText>
    <PrimaryDivider Class="m-1" />
    <MudStack Spacing="2">
        <DynamicComponent Type="@Section.ComponentType" Parameters="@Section.Parameters" />
    </MudStack>
</MudStack>

@if (Section.SubSections?.Count > 0)
{
    foreach (var subsection in Section.SubSections.OrderBy(x => x.Order))
    {
        <MudStack Class="px-4" Spacing="0">
            <MudText Typo="Typo.h6" Class="mud-text-secondary">
                @subsection.Name
            </MudText>
            <PrimaryDivider Class="m-1" />
            <MudStack Spacing="2">
                <DynamicComponent Type="@subsection.ComponentType" Parameters="@subsection.Parameters" />
            </MudStack>
        </MudStack>
    }
}

@code {
    [Parameter] public Section Section { get; set; } = default!;
}