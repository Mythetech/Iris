@page "/"

@using Iris.Cloud.Demo.Contracts

<MudContainer Class="d-flex pa-4" Style="min-height:75vh;min-width:100vw;">
    <MudStack Class="mud-width-full">
        <MudToggleGroup T="string" SelectionMode="SelectionMode.SingleSelection" @bind-Value="_receiveMode" Color="Color.Primary" FixedContent>
            <MudToggleItem Value="@("Normal")" Text="Normal">
                <MudIcon Icon="@Icons.Material.Outlined.Colorize" />
                <MudText>
                    Normal
                </MudText>
            </MudToggleItem>
            <MudToggleItem Value="@("Inverted")" Text="Inverted">
                <MudIcon Icon="@Icons.Material.Outlined.InvertColors" />
                <MudText>
                    Inverted
                </MudText>
            </MudToggleItem>
            <MudToggleItem Value="@("Random")" Text="Random">
                <MudIcon Icon="@Icons.Material.Outlined.Palette" />
                <MudText>
                    Random
                </MudText>
            </MudToggleItem>
        </MudToggleGroup>
        <MudPaper Class="flex-grow-1 mud-full-width" Style="@_style">

        </MudPaper>
    </MudStack>
</MudContainer>

@code {
    [Inject]
    protected DemoServiceBusClient Client { get; set; } = default!;


    [Inject]
    protected IConsumerNotifier<ChangeColorsCommand> NServiceBus { get; set; } = default!;

    [Inject]
    protected IConsumerNotifier<ChangeColorsCommandV2> Consumer { get; set; } = default!;

    private int R { get; set; } = 0;

    private int G { get; set; } = 0;

    private int B { get; set; } = 0;

    private Random Random { get; init; } = new();

    private bool ConnectedOnce { get; set; } = false;

    private string? _receiveMode = "Normal";

    private string? _style = $"background-color:rgb(0, 0, 0);justify-self:center;";

    private string SetRGBStyle(int r, int g, int b)
    {
        return $"background-color:rgb({r}, {g}, {b});justify-self:center;";
    }

    private string SetHSLStyle(int h, float s, float l)
    {
        return $"background-color:hsl({h}, {s}%, {l}%);justify-self:center;";
    }

    protected override async Task OnInitializedAsync()
    {
        if (!ConnectedOnce)
        {
            Client.ChangeColorsReceived += HandleColorChangeEvent;

            (NServiceBus as ChangeColorsCommandNotifier).HandleEvent += HandleColorChangeEvent;

            (Consumer as ChangeColorsCommandV2Notifier).HandleEvent += HandleMassTransitEvent;

            await Client.ConnectAsync();

            ConnectedOnce = true;
        }

        await base.OnInitializedAsync();
    }

    protected void Dispose()
    {
        Client.ChangeColorsReceived -= HandleColorChangeEvent;
        (NServiceBus as ChangeColorsCommandNotifier).HandleEvent -= HandleColorChangeEvent;
        (Consumer as ChangeColorsCommandV2Notifier).HandleEvent -= HandleMassTransitEvent;
    }

    protected async void HandleColorChangeEvent(ChangeColorsCommand args)
    {
        Console.WriteLine(args);


        switch (_receiveMode)
        {
            case "Normal":
                R = args.Red;
                G = args.Green;
                B = args.Blue;
                break;
            case "Inverted":
                R = 255 - args.Red;
                G = 255 - args.Green;
                B = 255 - args.Blue;
                break;
            case "Random":
                R = Random.Next(256);
                G = Random.Next(256);
                B = Random.Next(256);
                break;
            default:
                R = args.Red;
                G = args.Green;
                B = args.Blue;
                break;
        }

        _style = SetRGBStyle(R, G, B);

        await InvokeAsync(() => StateHasChanged());
    }

    protected async void HandleMassTransitEvent(ChangeColorsCommandV2 args)
    {
        Console.WriteLine(args);

        int h = args.Hue > 360 ? 360 : args.Hue < 0 ? 0 : args.Hue;
        float s = args.Saturation;
        float l = args.Light;

        switch (_receiveMode)
        {
            case "Normal":
                h = args.Hue;
                s = args.Saturation;
                l = args.Light;
                break;
            case "Inverted":
                h = 360 - args.Hue;
                s = 1 - args.Saturation;
                l = 1 - args.Light;
                break;
            case "Random":
                h = Random.Next(360);
                s = Random.Next(100) / 100.00f;
                l = Random.Next(100) / 100.00f;
                break;
            default:
                h = args.Hue;
                s = args.Saturation;
                l = args.Light;
                break;
        }

        _style = SetHSLStyle(h, s * 100, l * 100);

        await InvokeAsync(() => StateHasChanged());

    }
}